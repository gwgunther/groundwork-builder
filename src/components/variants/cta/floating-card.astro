---
/**
 * CTA Floating Card — Full-bleed background image, white card centered over it.
 * Dark overlay on image, card floats above.
 */
import type { CtaContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { imagePath } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

// Try hero or interior image
let imageRoles = {};
try {
  const p = `${process.cwd()}/public/images/image-roles.json`;
  imageRoles = JSON.parse(readFileSync(p, 'utf8'));
} catch {}
const ctaImg = imagePath(
  imageRoles.interior?.[0] ??
  imageRoles.team?.[0] ??
  imageRoles.hero ??
  null
);

const phone = content.phone || site.phone;
---

<section
  data-section="cta"
  class={`relative min-h-[500px] overflow-hidden flex items-center justify-center ${t.spacingClass}`}
>
  {ctaImg ? (
    <>
      <!-- Background image -->
      <img
        src={ctaImg}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
        aria-hidden="true"
      />
      <!-- Dark overlay -->
      <div class="absolute inset-0 bg-neutral-dark/50" aria-hidden="true"></div>
    </>
  ) : (
    <div class="absolute inset-0 bg-neutral-dark" aria-hidden="true"></div>
  )}

  <!-- Floating card -->
  <div class={`relative z-10 w-full max-w-lg mx-6 bg-surface-1 p-10 md:p-14 text-center ${t.radiusClass} shadow-2xl`}>
    {content.eyebrow && (
      <span class={t.eyebrowClass}>{content.eyebrow ?? ''}</span>
    )}
    <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-dark leading-tight mb-4">
      {content.headline}
    </h2>
    <p class="font-sans text-neutral-mid leading-relaxed mb-8">
      {content.subheadline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center flex-wrap">
      <a href={content.primaryCta.href} class={t.btnPrimary}>
        {content.primaryCta.label}
      </a>
      {phone && (
        <a
          href={`tel:${phone}`}
          class={`inline-flex items-center justify-center gap-2 px-6 py-3 ${t.radiusClass} font-semibold text-sm border-2 border-neutral-dark/20 text-neutral-dark hover:border-brand-primary hover:text-brand-primary transition-all duration-200 tabular-nums`}
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          {phone}
        </a>
      )}
    </div>
  </div>

</section>
