---
/**
 * Doctor Intro Split Photo — Portrait left, bio right (or reversed).
 * Standard warm/professional layout for dental sites.
 */
import type { DoctorIntroContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { imagePath } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

interface Props { content: DoctorIntroContent }
const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

// Load doctor portrait
let imageRoles: { doctorPortrait?: string | null } = {};
try {
  const p = `${process.cwd()}/public/images/image-roles.json`;
  imageRoles = JSON.parse(readFileSync(p, 'utf8'));
} catch {}
const portraitImg = imagePath(imageRoles.doctorPortrait ?? null);

// Reverse layout based on director DNA doctorVariant
const reversed = (designDNA as any).doctorVariant === 'portrait-right';
---

<section data-section="doctor-intro" class={`bg-brand-light ${t.spacingClass}`}>
  <div class={t.containerClass}>
    <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 lg:gap-20 items-center ${reversed ? 'md:[direction:rtl]' : ''}`}>

      <!-- Portrait -->
      <div class={`relative ${reversed ? '[direction:ltr]' : ''}`}>
        {portraitImg ? (
          <div class={`aspect-[4/5] overflow-hidden ${t.radiusClass}`}>
            <img
              src={portraitImg}
              alt={`${content.name}, ${content.credentials}`}
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
          </div>
        ) : (
          <!-- Placeholder when no portrait available -->
          <div class={`aspect-[4/5] bg-brand-primary/10 flex items-center justify-center ${t.radiusClass}`}>
            <span class="font-serif text-7xl font-bold text-brand-primary/30 select-none" aria-hidden="true">
              {content.name?.split(' ').pop()?.charAt(0) ?? 'D'}
            </span>
          </div>
        )}
        <!-- Decorative accent block -->
        <div
          class={`absolute -bottom-4 ${reversed ? 'right-4' : 'left-4'} md:${reversed ? '-right-4' : '-left-4'} w-24 h-24 bg-brand-primary/15 ${t.radiusClass} -z-10`}
          aria-hidden="true"
        ></div>
      </div>

      <!-- Text content -->
      <div class={reversed ? '[direction:ltr]' : ''}>
        {content.eyebrow && (
          <span class={t.eyebrowClass}>{content.eyebrow}</span>
        )}
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark mb-2">
          {content.name}
        </h2>
        <p class="font-sans text-sm font-semibold uppercase tracking-wider text-brand-primary mb-6">
          {content.credentials}
        </p>
        <div class="font-sans text-neutral-mid text-base leading-relaxed space-y-4 mb-8">
          {content.bio.split('\n\n').filter(Boolean).map((para) => (
            <p>{para}</p>
          ))}
        </div>
        <a href={content.ctaHref} class={t.btnPrimary}>
          {content.ctaLabel}
        </a>
      </div>

    </div>
  </div>
</section>
