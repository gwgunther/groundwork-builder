---
/**
 * Services Two-Col Feature — 1 large featured service left, compact list right.
 * 5-column asymmetric grid with vertical divider.
 */
import type { ServicesContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

const items = content.items ?? [];
const featured = items[0] ?? null;
const rest = items.slice(1, 5);
---

<section data-section="services" class={`bg-surface-1 ${t.spacingClass}`}>
  <div class={t.containerClass}>

    <!-- Section header -->
    <div class="max-w-2xl mb-12 md:mb-16">
      {content.eyebrow && (
        <span class={t.eyebrowClass}>{content.eyebrow}</span>
      )}
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark mb-4">
        {content.heading}
      </h2>
      {content.subheading && (
        <p class="font-sans text-lg text-neutral-mid leading-relaxed">
          {content.subheading}
        </p>
      )}
    </div>

    {items.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-5 gap-0 md:divide-x md:divide-border-light">

        <!-- Featured service — 3 of 5 columns -->
        {featured && (
          <div class="md:col-span-3 md:pr-12 pb-10 md:pb-0">
            <span class={`inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest bg-brand-primary/10 text-brand-primary ${t.radiusClass} mb-6`}>
              Featured
            </span>
            <!-- Dot accent -->
            <div class="flex items-center gap-3 mb-4" aria-hidden="true">
              <span class="w-3 h-3 rounded-full bg-brand-primary block shrink-0"></span>
              <span class="h-px flex-1 bg-brand-primary/20"></span>
            </div>
            <h3 class="font-serif text-2xl md:text-3xl font-bold text-neutral-dark mb-4">
              {featured.name}
            </h3>
            <p class="font-sans text-neutral-mid text-base leading-relaxed mb-8">
              {featured.desc}
            </p>
            {featured.slug && (
              <a href={`/services/${featured.slug}`} class={t.btnPrimary}>
                {content.ctaLabel || 'Learn More'}
              </a>
            )}
          </div>
        )}

        <!-- Compact list — 2 of 5 columns -->
        {rest.length > 0 && (
          <div class="md:col-span-2 md:pl-12 border-t border-border-light md:border-t-0 pt-10 md:pt-0">
            <ul class="divide-y divide-border-light list-none p-0" role="list">
              {rest.map((service) => (
                <li>
                  <a
                    href={`/services/${service.slug}`}
                    class="group flex flex-col py-4 gap-1 no-underline"
                    aria-label={`Learn about ${service.name}`}
                  >
                    <span class="font-serif text-base font-bold text-neutral-dark group-hover:text-brand-primary transition-colors">
                      {service.name}
                    </span>
                    <span class="font-sans text-neutral-mid text-sm leading-snug">
                      {service.desc}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
            <div class="pt-6">
              <a
                href="/services"
                class="inline-flex items-center gap-1 text-brand-primary text-sm font-semibold hover:gap-2 transition-all"
              >
                View all services
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        )}

      </div>
    )}

  </div>
</section>
