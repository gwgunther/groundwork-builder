---
/**
 * Services Accordion — Expandable service list using Alpine.js.
 * Clean, professional. First item open by default.
 */
import type { ServicesContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);
---

<section data-section="services" class={`bg-surface-1 ${t.spacingClass}`}>
  <div class={t.containerClass}>

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      {content.eyebrow && (
        <span class={t.eyebrowClass}>{content.eyebrow}</span>
      )}
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark mb-4">
        {content.heading}
      </h2>
      {content.subheading && (
        <p class="font-sans text-lg text-neutral-mid leading-relaxed">
          {content.subheading}
        </p>
      )}
    </div>

    <!-- Accordion list -->
    {content.items && content.items.length > 0 && (
      <div class="max-w-3xl mx-auto divide-y divide-border-light">
        {content.items.map((service, i) => (
          <div x-data={`{ open: ${i === 0 ? 'true' : 'false'} }`}>
            <button
              type="button"
              @click="open = !open"
              class="w-full flex items-center justify-between gap-4 py-6 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-inset"
              :aria-expanded="open"
              aria-controls={`service-body-${i}`}
            >
              <span class="font-serif text-xl font-semibold text-neutral-dark">
                {service.name}
              </span>
              <!-- Chevron -->
              <svg
                class="w-5 h-5 text-brand-primary shrink-0 transition-transform duration-200"
                :class="{ 'rotate-180': open }"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div
              id={`service-body-${i}`}
              x-show="open"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
            >
              <div class="pb-6 pr-10">
                <p class="font-sans text-neutral-mid text-base leading-relaxed mb-4">
                  {service.desc}
                </p>
                {service.slug && (
                  <a
                    href={`/services/${service.slug}`}
                    class="inline-flex items-center gap-1 text-brand-primary text-sm font-semibold hover:gap-2 transition-all"
                  >
                    Learn more
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- View all CTA -->
    <div class="text-center mt-12">
      <a href="/services" class={t.btnPrimary}>
        {content.ctaLabel || 'View All Services'}
      </a>
    </div>

  </div>
</section>
