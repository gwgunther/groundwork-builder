---
/**
 * Hero Text Only — No image. Pure typographic impact.
 * Enormous display heading on dark background. Swiss editorial poster feel.
 */
import type { HeroContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { resolveTokens } from '../token-utils';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

const phone = content.phone || site.phone;
---

<section
  data-section="hero"
  class="bg-neutral-dark text-white py-24 md:py-40"
>
  <div class={`${t.containerClass} max-w-5xl`}>

    <!-- Eyebrow -->
    {content.eyebrow && (
      <span class="block text-sm font-bold uppercase tracking-widest text-brand-primary mb-6">
        {content.eyebrow}
      </span>
    )}

    <!-- Display heading -->
    <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold leading-none text-white mb-6">
      {content.headline}
    </h1>

    <!-- Subheadline -->
    <p class="text-white/70 text-lg md:text-xl max-w-xl leading-relaxed mb-10">
      {content.subheadline}
    </p>

    <!-- Divider -->
    <hr class="border-white/10 mb-10" />

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 items-start flex-wrap">
      <a
        href={content.primaryCta.href}
        class={`inline-flex items-center justify-center px-6 py-3 ${t.radiusClass} bg-white text-neutral-dark font-semibold text-sm hover:bg-white/90 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-dark`}
      >
        {content.primaryCta.label}
      </a>
      {content.secondaryCta && (
        <a
          href={content.secondaryCta.href}
          class={`inline-flex items-center justify-center px-6 py-3 ${t.radiusClass} border-2 border-white/30 text-white font-semibold text-sm hover:border-white hover:bg-white/10 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-dark`}
        >
          {content.secondaryCta.label}
        </a>
      )}
    </div>

    <!-- Phone -->
    {phone && (
      <a
        href={`tel:${phone}`}
        class="inline-flex items-center gap-2 font-serif text-2xl text-white/60 mt-8 hover:text-white/80 transition-colors tabular-nums"
        aria-label={`Call us at ${phone}`}
      >
        <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        {phone}
      </a>
    )}

  </div>
</section>
