---
/**
 * Hero Centered — Full-bleed image with centered text overlay.
 * Eyebrow → Headline → Subheadline → 2 CTAs → Phone.
 */
import type { HeroContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { imagePath } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

interface Props { content: HeroContent }
const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

// Load hero image
let imageRoles: { hero?: string | null } = {};
try {
  const p = `${process.cwd()}/public/images/image-roles.json`;
  imageRoles = JSON.parse(readFileSync(p, 'utf8'));
} catch {}
const heroImg = imagePath(imageRoles.hero ?? null);

const phone = content.phone || site.phone;
---

<section
  data-section="hero"
  class={`relative min-h-[80vh] flex items-center justify-center overflow-hidden ${t.spacingClass}`}
>
  <!-- Background image -->
  {heroImg && (
    <img
      src={heroImg}
      alt={`${site.name} practice`}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
  )}
  <!-- Overlay -->
  <div class={`absolute inset-0 bg-neutral-dark ${heroImg ? 'opacity-55' : 'opacity-90'}`}></div>

  <!-- Content -->
  <div class={`relative z-10 text-center ${t.containerClass} max-w-4xl`}>
    {content.eyebrow && (
      <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest bg-white/15 text-white rounded mb-6">
        {content.eyebrow}
      </span>
    )}
    <h1 class="font-serif text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
      {content.headline}
    </h1>
    <p class="font-sans text-lg md:text-xl text-white/85 leading-relaxed mb-8 max-w-2xl mx-auto">
      {content.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
      <a href={content.primaryCta.href} class={t.btnPrimary}>
        {content.primaryCta.label}
      </a>
      {content.secondaryCta && (
        <a href={content.secondaryCta.href} class={t.btnSecondary}>
          {content.secondaryCta.label}
        </a>
      )}
    </div>

    <!-- Phone -->
    {phone && (
      <a
        href={`tel:${phone}`}
        class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors font-sans text-base tabular-nums"
        aria-label={`Call us at ${phone}`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        {phone}
      </a>
    )}
  </div>
</section>
