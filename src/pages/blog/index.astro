---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../../config/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title={`Blog — ${site.name}`}
  description={`Dental health tips, treatment guides, and news from ${site.name}.`}
>
  <section class="bg-surface-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-heading mb-6">Patient Blog</h1>
        <p class="text-lg text-neutral-mid">
          Helpful articles about dental health, treatment options, and tips for keeping your smile at its best.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 && (
        <p class="text-center text-mid-gray text-lg">Blog posts coming soon.</p>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="card hover:border-brand-primary/30 transition-colors group">
            <p class="text-xs text-mid-gray mb-2">
              {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-serif text-lg font-semibold text-charcoal mb-2 group-hover:text-brand-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-mid-gray">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
