---
import { site, doctor, address as addr } from '../config/site'
import { designDNA } from '../config/design-dna'



const currentYear = new Date().getFullYear()

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Blog', href: '/blog' },
  { label: 'Schedule', href: '/schedule' },
]
---

<footer class="w-full bg-neutral-dark text-white">
  <!-- Top rule in brand-primary (gold accent) -->
  <div class="h-px w-full bg-brand-primary"></div>

  <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Col 1: Practice identity -->
      <div class="flex flex-col gap-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-primary">
          Specialist Practice
        </p>
        <p class="font-serif text-xl font-bold leading-snug text-white">
          {site.name}
        </p>
        <p class="text-base leading-relaxed text-neutral-400">
          Board-certified specialist serving Los Alamitos and the surrounding communities of Southern California.
        </p>
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/changortho/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-neutral-400 hover:text-brand-primary transition-all duration-200"
          aria-label="Russell EK Chang DDS on Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M22 12c0-5.522-4.478-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
          <span class="text-sm font-medium">Facebook</span>
        </a>
      </div>

      <!-- Col 2: Address & contact -->
      <div class="flex flex-col gap-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-primary">
          Location
        </p>
        <address class="not-italic flex flex-col gap-2">
          <p class="text-base leading-relaxed text-neutral-300">
            {addr.street}<br />
            {addr.city}, {addr.state} {addr.zip}
          </p>
          <a
            href={`tel:${site.phone.replace(/\D/g, '')}`}
            class="text-base font-semibold text-white hover:text-brand-primary transition-all duration-200"
          >
            {site.phone}
          </a>
        </address>
        <a
          href="/schedule"
          class="inline-block border border-brand-primary text-brand-primary font-semibold px-6 py-3 rounded-2xl transition-all duration-200 text-center hover:bg-brand-primary hover:text-white mt-2 w-fit"
        >
          Request Appointment
        </a>
      </div>

      <!-- Col 3: Office hours -->
      <div class="flex flex-col gap-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-primary">
          Office Hours
        </p>
        {site.hours ? (
          <ul class="flex flex-col gap-2">
            {Object.entries(site.hours).map(([day, hours]) => (
              <li class="flex justify-between gap-4 text-sm text-neutral-300">
                <span class="font-medium text-white">{day}</span>
                <span>{hours}</span>
              </li>
            ))}
          </ul>
        ) : (
          <ul class="flex flex-col gap-2 text-sm text-neutral-300">
            <li class="flex justify-between gap-4">
              <span class="font-medium text-white">Mon – Thu</span>
              <span>8:00 am – 5:00 pm</span>
            </li>
            <li class="flex justify-between gap-4">
              <span class="font-medium text-white">Friday</span>
              <span>8:00 am – 2:00 pm</span>
            </li>
            <li class="flex justify-between gap-4">
              <span class="font-medium text-white">Sat – Sun</span>
              <span>Closed</span>
            </li>
          </ul>
        )}
      </div>

      <!-- Col 4: Navigation -->
      <div class="flex flex-col gap-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-primary">
          Navigate
        </p>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-3">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-base text-neutral-300 hover:text-brand-primary transition-all duration-200 font-medium"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-neutral-700">
    <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-500">
        &copy; {currentYear} {site.name}. All rights reserved.
      </p>
      <p class="text-sm text-neutral-500">
        {addr.city}, {addr.state}
      </p>
    </div>
  </div>
</footer>