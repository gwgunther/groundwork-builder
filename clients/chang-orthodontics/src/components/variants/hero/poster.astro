---
/**
 * Hero Poster — Full-bleed image, NO overlay. Text in a floating card
 * pinned to the bottom. The image IS the hero — no dimming.
 */
import type { HeroContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { imagePath } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

// Load hero image
let imageRoles = {};
try {
  const p = `${process.cwd()}/public/images/image-roles.json`;
  imageRoles = JSON.parse(readFileSync(p, 'utf8'));
} catch {}
const heroImg = imagePath(imageRoles.hero ?? null);

const phone = content.phone || site.phone;
---

<section
  data-section="hero"
  class="relative min-h-[85vh] overflow-hidden"
>
  {heroImg ? (
    <>
      <!-- Full-bleed image — NO overlay -->
      <img
        src={heroImg}
        alt={`${site.name} practice`}
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Floating text card -->
      <div class={`absolute bottom-8 left-8 right-8 md:left-12 md:right-auto md:max-w-xl bg-white/95 backdrop-blur-sm p-8 md:p-10 ${t.radiusClass}`}>
        {content.eyebrow && (
          <span class={t.eyebrowClass}>{content.eyebrow}</span>
        )}
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark leading-tight mb-4">
          {content.headline}
        </h1>
        <p class="font-sans text-neutral-mid leading-relaxed mb-6">
          {content.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 flex-wrap">
          <a href={content.primaryCta.href} class={t.btnPrimary}>
            {content.primaryCta.label}
          </a>
          {content.secondaryCta && (
            <a
              href={content.secondaryCta.href}
              class={`inline-flex items-center justify-center px-6 py-3 ${t.radiusClass} font-semibold text-sm border-2 border-neutral-dark/20 text-neutral-dark hover:border-brand-primary hover:text-brand-primary transition-all duration-200`}
            >
              {content.secondaryCta.label}
            </a>
          )}
          {phone && (
            <a
              href={`tel:${phone}`}
              class="inline-flex items-center gap-2 text-neutral-mid hover:text-brand-primary transition-colors font-sans text-sm tabular-nums self-center"
              aria-label={`Call us at ${phone}`}
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
              {phone}
            </a>
          )}
        </div>
      </div>
    </>
  ) : (
    <!-- No image fallback: brand-primary background, centered text -->
    <div class={`flex flex-col justify-center min-h-[85vh] bg-brand-primary ${t.spacingClass} px-8 md:px-12`}>
      <div class="max-w-2xl">
        {content.eyebrow && (
          <span class="block text-sm font-semibold uppercase tracking-widest text-white/70 mb-3">
            {content.eyebrow}
          </span>
        )}
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          {content.headline}
        </h1>
        <p class="font-sans text-lg text-white/80 leading-relaxed mb-8">
          {content.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 flex-wrap">
          <a
            href={content.primaryCta.href}
            class={`inline-flex items-center justify-center px-6 py-3 ${t.radiusClass} bg-white text-brand-primary font-semibold text-sm hover:bg-white/90 transition-all duration-200`}
          >
            {content.primaryCta.label}
          </a>
          {content.secondaryCta && (
            <a
              href={content.secondaryCta.href}
              class={`inline-flex items-center justify-center px-6 py-3 ${t.radiusClass} border-2 border-white/30 text-white font-semibold text-sm hover:border-white hover:bg-white/10 transition-all duration-200`}
            >
              {content.secondaryCta.label}
            </a>
          )}
        </div>
      </div>
    </div>
  )}
</section>
