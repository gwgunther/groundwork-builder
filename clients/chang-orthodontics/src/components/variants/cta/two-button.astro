---
/**
 * CTA Two Button — Two equally prominent CTAs: Book Appointment + Call Us.
 * Phone number displayed large as button label. High-call-volume practices.
 */
import type { CtaContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { resolveTokens } from '../token-utils';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

const phone = content.phone || site.phone;
---

<section
  data-section="cta"
  class={`bg-brand-light ${t.spacingClass}`}
>
  <div class={`${t.containerClass} max-w-2xl text-center`}>

    <h2 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark text-center leading-tight mb-4">
      {content.headline}
    </h2>
    <p class="font-sans text-neutral-mid text-center leading-relaxed mb-8">
      {content.subheadline}
    </p>

    <!-- Two-button row -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
      <!-- Button 1: Book appointment -->
      <a href={content.primaryCta.href} class={t.btnPrimary}>
        {content.primaryCta.label}
      </a>

      <!-- Button 2: Call us — phone number as label -->
      {phone && (
        <a
          href={`tel:${phone}`}
          class={`inline-flex items-center justify-center gap-2 px-6 py-3 ${t.radiusClass} font-semibold text-sm border-2 border-neutral-dark/20 text-neutral-dark hover:border-brand-primary hover:text-brand-primary transition-all duration-200 tabular-nums focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2`}
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          {phone}
        </a>
      )}
    </div>

    <!-- Trust line -->
    <p class="font-sans text-neutral-mid text-xs mt-6">
      No referral needed · Same-week appointments available
    </p>

  </div>
</section>
