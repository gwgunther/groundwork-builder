---
/**
 * CTA Inline Minimal — No image. Horizontal strip with brand-primary left border accent.
 * Headline left, CTA + phone right. Elegant, unobtrusive.
 */
import type { CtaContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { site } from '../../../config/site';
import { resolveTokens } from '../token-utils';

const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

const phone = content.phone || site.phone;
---

<section
  data-section="cta"
  class="border-t border-b border-border-light py-12 md:py-16 bg-surface-1"
>
  <div class={`${t.containerClass} flex flex-col md:flex-row md:items-center md:justify-between gap-6`}>

    <!-- Left: accent bar + headline -->
    <div class="flex items-start gap-5">
      <div class="w-1 h-12 bg-brand-primary shrink-0 mt-1" aria-hidden="true"></div>
      <div>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-dark leading-tight">
          {content.headline}
        </h2>
        {content.subheadline && (
          <p class="font-sans text-neutral-mid text-sm mt-1 max-w-md">
            {content.subheadline}
          </p>
        )}
      </div>
    </div>

    <!-- Right: CTA button + phone -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 shrink-0">
      <a href={content.primaryCta.href} class={t.btnPrimary}>
        {content.primaryCta.label}
      </a>
      {phone && (
        <a
          href={`tel:${phone}`}
          class="inline-flex items-center gap-2 text-neutral-dark hover:text-brand-primary transition-colors font-semibold text-base tabular-nums"
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-4 h-4 shrink-0 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          {phone}
        </a>
      )}
    </div>

  </div>
</section>
