---
/**
 * Reviews Card Row — 3 testimonial cards in a row with stars.
 * Standard social-proof layout for warm/service brands.
 */
import type { ReviewsContent } from '../types';
import { designDNA } from '../../../config/design-dna';
import { resolveTokens } from '../token-utils';

interface Props { content: ReviewsContent }
const { content } = Astro.props;

const tokens = (designDNA as any).designTokens ?? {};
const t = resolveTokens(tokens);

const cardClass = {
  'bordered-flat':  'border border-neutral-dark/10 bg-surface-1',
  'soft-shadow':    'bg-surface-1 shadow-md',
  'elevated':       'bg-surface-1 shadow-lg',
  'ghost':          'bg-brand-light border border-brand-primary/10',
}[(designDNA as any).cardTreatment] ?? 'bg-surface-1 shadow-md';

function renderStars(rating: number = 5) {
  return Array.from({ length: 5 }, (_, i) => i < Math.round(rating) ? '★' : '☆').join('');
}
---

<section data-section="reviews" class={`bg-brand-light ${t.spacingClass}`}>
  <div class={t.containerClass}>

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      {content.eyebrow && (
        <span class={t.eyebrowClass}>{content.eyebrow}</span>
      )}
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-neutral-dark mb-2">
        {content.heading}
      </h2>
      {content.aggregateRating && content.reviewCount && (
        <p class="font-sans text-neutral-mid text-sm mt-2">
          <span class="text-brand-primary font-bold">{content.aggregateRating}/5</span>
          {' '}from {content.reviewCount}+ reviews
        </p>
      )}
    </div>

    <!-- Cards -->
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none p-0" role="list">
      {content.items.slice(0, 3).map((review) => (
        <li class={`flex flex-col p-6 md:p-8 ${t.radiusClass} ${cardClass}`}>
          <div class="text-brand-primary text-xl mb-4 tracking-widest" aria-label={`${review.rating ?? 5} out of 5 stars`}>
            {renderStars(review.rating)}
          </div>
          <blockquote class="font-sans text-neutral-mid text-sm leading-relaxed italic flex-grow mb-4">
            "{review.quote}"
          </blockquote>
          <footer>
            <cite class="font-sans text-neutral-dark text-sm font-semibold not-italic">
              — {review.author}
            </cite>
          </footer>
        </li>
      ))}
    </ul>

    <!-- Google link -->
    {content.googleUrl && (
      <div class="text-center mt-10">
        <a
          href={content.googleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-sans text-sm font-semibold text-neutral-mid hover:text-brand-primary transition-colors"
          aria-label="Read more reviews on Google (opens in new tab)"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Read all reviews on Google ↗
        </a>
      </div>
    )}
  </div>
</section>
