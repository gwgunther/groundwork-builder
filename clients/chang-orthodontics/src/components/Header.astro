---
import { site, doctor, address as addr } from '../config/site'
import { designDNA } from '../config/design-dna'


---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-200">
  <nav
    class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16"
    aria-label="Main navigation"
    x-data="{ mobileOpen: false }"
  >

    <!-- Logo / Practice Name -->
    <a
      href="/"
      class="flex-shrink-0 font-serif font-bold text-neutral-dark text-lg leading-tight tracking-tight hover:opacity-80 transition-all duration-200 max-w-[200px]"
      aria-label="Russell EK Chang, DDS, MS, FACD — Home"
    >
      <span class="block text-brand-primary text-xs font-semibold uppercase tracking-widest mb-0.5">Orthodontics</span>
      <span class="whitespace-nowrap">Russell EK Chang</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">

      <!-- Meet Chang -->
      <a
        href="/about"
        class="whitespace-nowrap text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200"
      >
        Meet Chang
      </a>

      <!-- Services Dropdown -->
      <div class="relative group">
        <button
          class="whitespace-nowrap flex items-center gap-1 text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 rounded"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Services
          <svg class="w-3.5 h-3.5 mt-0.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown panel — pt-2 bridges hover gap, no mt-2 -->
        <div class="absolute top-full left-0 pt-2 w-64 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
          <div class="bg-white rounded-2xl border border-neutral-200 shadow-md py-2 overflow-hidden">
            <a href="/services/clear-ceramic-braces"   class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Clear (Ceramic) Braces</a>
            <a href="/services/clear-aligners"         class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Clear Aligners</a>
            <a href="/services/coconut-wireless"       class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Coconut Wireless</a>
            <a href="/services/craniofacial-orthodontics" class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Craniofacial Orthodontics</a>
            <a href="/services/damon-smile"            class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Damon™ Smile</a>
            <a href="/services/dentofacial-orthopedics" class="whitespace-nowrap block px-5 py-2.5 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-brand-primary transition-all duration-150">Dentofacial Orthopedics</a>
            <div class="my-1.5 border-t border-neutral-100"></div>
            <a href="/services" class="whitespace-nowrap block px-5 py-2.5 text-sm font-semibold text-brand-primary hover:bg-neutral-50 transition-all duration-150">
              All Services →
            </a>
          </div>
        </div>
      </div>

      <!-- Blog -->
      <a
        href="/blog"
        class="whitespace-nowrap text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200"
      >
        Blog
      </a>

      <!-- FAQ -->
      <a
        href="/faq"
        class="whitespace-nowrap text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200"
      >
        FAQ
      </a>

    </div>

    <!-- Desktop Right: Phone + CTA -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="tel:+15624300541"
        class="whitespace-nowrap tabular-nums text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 min-h-[44px] flex items-center"
        aria-label="Call our office at (562) 430-0541"
      >
        (562) 430-0541
      </a>
      <a
        href="/schedule"
        class="inline-block bg-brand-primary text-white font-semibold px-6 py-3 rounded-2xl transition-all duration-200 text-center hover:opacity-90 whitespace-nowrap ml-6 min-h-[44px] flex items-center"
      >
        Book Appointment
      </a>
    </div>

    <!-- Mobile: Phone + Hamburger -->
    <div class="flex md:hidden items-center gap-3">
      <a
        href="tel:+15624300541"
        class="tabular-nums text-sm font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 min-h-[44px] min-w-[44px] flex items-center"
        aria-label="Call (562) 430-0541"
      >
        (562) 430-0541
      </a>
      <button
        @click="mobileOpen = !mobileOpen"
        class="min-h-[44px] min-w-[44px] flex items-center justify-center text-neutral-700 hover:text-brand-primary transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary rounded"
        :aria-expanded="mobileOpen"
        aria-label="Toggle navigation menu"
      >
        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg x-show="mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

  </nav>

  <!-- Mobile Menu Panel -->
  <div
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="md:hidden border-t border-neutral-200 bg-white"
    x-data="{ servicesOpen: false }"
  >
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">

      <a
        href="/about"
        class="block py-3 text-base font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 border-b border-neutral-100"
        @click="mobileOpen = false"
      >
        Meet Chang
      </a>

      <!-- Mobile Services Accordion -->
      <div class="border-b border-neutral-100">
        <button
          @click="servicesOpen = !servicesOpen"
          class="w-full flex items-center justify-between py-3 text-base font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200"
          :aria-expanded="servicesOpen"
        >
          <span>Services</span>
          <svg
            class="w-4 h-4 transition-transform duration-200"
            :class="servicesOpen ? 'rotate-180' : ''"
            fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div x-show="servicesOpen" x-transition class="pb-2 pl-4 flex flex-col gap-0.5">
          <a href="/services/clear-ceramic-braces"      class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Clear (Ceramic) Braces</a>
          <a href="/services/clear-aligners"            class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Clear Aligners</a>
          <a href="/services/coconut-wireless"          class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Coconut Wireless</a>
          <a href="/services/craniofacial-orthodontics" class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Craniofacial Orthodontics</a>
          <a href="/services/damon-smile"               class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Damon™ Smile</a>
          <a href="/services/dentofacial-orthopedics"   class="block py-2 text-sm text-neutral-600 hover:text-brand-primary transition-all duration-150" @click="mobileOpen = false">Dentofacial Orthopedics</a>
          <a href="/services"                           class="block py-2 text-sm font-semibold text-brand-primary hover:opacity-80 transition-all duration-150" @click="mobileOpen = false">All Services →</a>
        </div>
      </div>

      <a
        href="/blog"
        class="block py-3 text-base font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 border-b border-neutral-100"
        @click="mobileOpen = false"
      >
        Blog
      </a>

      <a
        href="/faq"
        class="block py-3 text-base font-semibold text-neutral-700 hover:text-brand-primary transition-all duration-200 border-b border-neutral-100"
        @click="mobileOpen = false"
      >
        FAQ
      </a>

      <div class="pt-4 pb-2">
        <a
          href="/schedule"
          class="inline-block bg-brand-primary text-white font-semibold px-6 py-3 rounded-2xl transition-all duration-200 text-center hover:opacity-90 w-full text-center"
          @click="mobileOpen = false"
        >
          Book Appointment
        </a>
      </div>

    </div>
  </div>

</header>