---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Dentofacial Orthopedics",
  "description": "Specialist-level guidance of jaw and facial bone development — performed by a Board-Certified Diplomate of the American Board of Orthodontics.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Dentofacial Orthopedics | ${site.name}`}
  description="Specialist-level guidance of jaw and facial bone development — performed by a Board-Certified Diplomate of the American Board of Orthodontics."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Dentofacial Orthopedics
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      Specialist-level guidance of jaw and facial bone development — performed by a Board-Certified Diplomate of the American Board of Orthodontics.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">You may have noticed that our doctor specializes in &quot;orthodontics and dentofacial orthopedics.&quot; While most people have heard of orthodontics, many are confused by the dentofacial orthopedics part of the specialty. Dentofacial orthopedics involves the diagnosis and treatment of dental and facial irregularities — specifically the guidance of facial growth and development, which can occur at any age but is most often addressed in growing patients. Every orthodontist starts out in dental school; upon completion, some choose to pursue the orthodontic specialty, which requires additional years of advanced training. Dr. Chang is a Board Certified Diplomate of the American Board of Orthodontics and a USC Assistant Adjunct Professor of Postdoctoral Orthodontics, bringing both academic and clinical depth to the management of jaw development and alignment. The iTero Digital Impression System supports precise diagnostics throughout your treatment.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Addresses both tooth alignment and underlying jaw and facial bone development</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Most effective when initiated during growth — but applicable at any age</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Delivered by a Board-Certified Diplomate of the American Board of Orthodontics</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>iTero digital scanning for accurate treatment planning</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Request an Evaluation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
