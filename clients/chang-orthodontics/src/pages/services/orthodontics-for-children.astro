---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Orthodontics for Children",
  "description": "The American Association of Orthodontists recommends an orthodontic evaluation by age seven — early diagnosis leads to better outcomes.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Orthodontics for Children | ${site.name}`}
  description="The American Association of Orthodontists recommends an orthodontic evaluation by age seven — early diagnosis leads to better outcomes."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Orthodontics for Children
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      The American Association of Orthodontists recommends an orthodontic evaluation by age seven — early diagnosis leads to better outcomes.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">While there is no exact age for children to begin orthodontic treatment, the American Association of Orthodontists recommends visiting the orthodontist around age seven. By this age, most children have a mix of baby teeth and adult teeth, making it easier for the orthodontist to diagnose and correct tooth and jaw problems sooner and without surgery. For parents, it's not always easy to know if your child may need orthodontic treatment. Early treatment allows your orthodontist to correct and guide the growth of your child's jaw to help the permanent teeth come in straight, regulate the width of the upper and lower arches, create more space for crowded teeth, and avoid the need for permanent tooth extractions later. At Chang Orthodontics, both Dr. Chang and Dr. Chung serve as USC Adjunct Assistant Professors of Postdoctoral Orthodontics and Pediatric Dentistry. Our practice has a recognized commitment to children with special needs, and Dr. Chang is an active member of the Cleft Lip and Palate Team at Miller Children's Hospital. Consultations are complimentary — please contact our practice to schedule your child's evaluation.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>AAO-recommended evaluation at age seven</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Early diagnosis can prevent more complex treatment later</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Guides jaw development during active growth phases</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Specialist care for children with special needs and craniofacial conditions</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Complimentary initial consultation</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Schedule a Complimentary Consultation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
