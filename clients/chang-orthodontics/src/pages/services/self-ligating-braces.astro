---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Self-Ligating Braces",
  "description": "Bracket technology that eliminates elastic ties — fewer appointments, less friction, and more efficient tooth movement.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Self-Ligating Braces | ${site.name}`}
  description="Bracket technology that eliminates elastic ties — fewer appointments, less friction, and more efficient tooth movement."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Self-Ligating Braces
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      Bracket technology that eliminates elastic ties — fewer appointments, less friction, and more efficient tooth movement.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">Self-ligating braces are made from the same materials as traditional braces. However, self-ligating braces do not require the use of elastics, meaning fewer appointments and less friction being placed on the tooth. By using a built-in mechanism — either a passive or active clip — to hold the archwire, self-ligating brackets allow teeth to move more freely and comfortably throughout treatment. This reduction in friction can contribute to shorter overall treatment times and a more comfortable experience between visits. Chang Orthodontics offers both the In-Ovation self-ligating system and LightForce custom 3D-printed brackets, giving patients access to some of the most advanced bracket technology available in orthodontics today.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>No elastic ties — reduced friction on teeth throughout treatment</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Fewer adjustment appointments required</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Teeth move more freely and comfortably</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>In-Ovation and LightForce self-ligating options available</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Schedule a Consultation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
