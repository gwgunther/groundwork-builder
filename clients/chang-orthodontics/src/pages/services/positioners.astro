---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Positioners",
  "description": "A finishing appliance used at the end of orthodontic treatment to refine tooth position and settle the bite.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Positioners | ${site.name}`}
  description="A finishing appliance used at the end of orthodontic treatment to refine tooth position and settle the bite."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Positioners
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      A finishing appliance used at the end of orthodontic treatment to refine tooth position and settle the bite.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">A tooth positioner is a flexible, removable appliance worn during the final stage of orthodontic treatment to complete the last minor tooth movements and allow the teeth to settle into their ideal occlusal relationship. Positioners are typically made of a soft rubber or plastic material and are worn for a limited period following brace removal, helping to refine alignment and ensure a stable, well-seated bite before the final retainer phase begins. At Chang Orthodontics, your progress with finishing appliances is reviewed by Dr. Chang or Dr. Chung at every appointment — not delegated to staff — ensuring the precision this final stage of treatment requires.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Refines final tooth position after active orthodontic treatment</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Helps settle the bite for a more stable long-term result</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Removable appliance worn for a limited finishing period</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Monitored directly by your orthodontist at every visit</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Schedule a Consultation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
