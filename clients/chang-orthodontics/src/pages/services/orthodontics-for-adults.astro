---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Orthodontics for Adults",
  "description": "It's never too late for a healthier bite and a more confident smile — delivered by a Board-Certified Diplomate with Invisalign Diamond Provider status.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Orthodontics for Adults | ${site.name}`}
  description="Orthodontics for Adults at Russell EK Chang, DDS, MS, FACD, Inc. in Los Alamitos."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Orthodontics for Adults
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      It's never too late for a healthier bite and a more confident smile — delivered by a Board-Certified Diplomate with Invisalign Diamond Provider status.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">Orthodontic treatment is effective at any age, and adults represent a growing segment of orthodontic patients seeking both functional and aesthetic correction. Whether your concern is crowding, spacing, a misaligned bite, or teeth that have shifted after previous treatment, Chang Orthodontics offers a full range of options — including Invisalign clear aligners, LightForce custom 3D-printed brackets, InBrace lingual braces, and traditional fixed appliances — tailored to adult lifestyles and clinical needs. Dr. Chang is a Board Certified Diplomate of the American Board of Orthodontics with over 40 years of quality care in Los Alamitos. Your complimentary initial consultation includes a complete orthodontic exam performed by Dr. Chang himself, with a customized treatment plan and flexible payment options discussed before any commitment is made.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Full range of adult-appropriate treatment options including Invisalign and InBrace</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Invisalign Diamond Provider — extensive aligner case experience</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Board-Certified Diplomate of the American Board of Orthodontics</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Complimentary consultation with customized treatment planning</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Flexible payment plans to fit your budget</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Schedule a Complimentary Consultation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
