---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, localBusinessSchema } from '../../config/site';

const procedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Orthodontic Retention",
  "description": "Your treatment is complete — now keep your results for life.",
  "procedureType": "https://schema.org/Therapeutic",
  "provider": {
    "@type": "Dentist",
    "name": "Russell EK Chang, DDS, MS, FACD, Inc.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Los Alamitos"
    }
  }
};
---

<BaseLayout
  title={`Orthodontic Retention | ${site.name}`}
  description="Your treatment is complete — now keep your results for life."
  schema={[localBusinessSchema, procedureSchema]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">
      <a href="/services" class="hover:underline">Services</a>
    </p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-dark mb-4 leading-tight">
      Orthodontic Retention
    </h1>
    <p class="text-xl text-neutral-mid mb-8 leading-relaxed">
      Your treatment is complete — now keep your results for life.
    </p>
    <div class="prose prose-lg max-w-none text-neutral-mid leading-relaxed">
      <p class="mb-4">Finally, your braces have been removed and your smile is beautiful, straight, and best of all, metal-free! However, your orthodontic journey isn't quite completed. To keep your smile looking its best, you'll need to wear a retainer to preserve and stabilize your results. Retainers are custom-made and can be removable or fixed. Chang Orthodontics uses the iTero Digital Impression System to ensure your retainer is fabricated from a precise digital record of your corrected dentition. Our practice also offers InBrace lingual retainer options and LightForce technology, and our facility maintains IQAir clean air certification — supporting your health throughout the retention phase and beyond.</p>
      <ul class="space-y-3 my-6">
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>Custom-made retainers — removable or fixed based on your needs</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>iTero digital impressions used for precise retainer fabrication</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>InBrace lingual retainer option available</span></li>
        <li class="flex gap-3"><span class="text-brand-primary font-bold mt-1">→</span><span>IQAir-certified clean air facility for all appointments</span></li>
      </ul>
    </div>
    <div class="mt-10 flex gap-4 flex-wrap">
      <a href="/schedule" class="btn-primary">Schedule a Retention Consultation</a>
      <a href="/services" class="btn-secondary">View All Services</a>
    </div>
  </div>
</BaseLayout>
