# Anthropic API (for AI pipeline steps — site audit, copy strategy, etc.)
ANTHROPIC_API_KEY=

# Google Analytics 4
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: override the displayed phone with a Google Ads call-extension
# forwarding number (or any per-deployment number). Leave blank to use the
# real practice phone from src/config/site.ts. Schema (telephone) always
# keeps the real number for NAP-consistent local SEO.
PUBLIC_DISPLAY_PHONE=

# Google API (for automation scripts)
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json
GSC_SITE_URL=https://[DOMAIN]/
GA4_PROPERTY_ID=

# Google Business Profile (OAuth — for automation scripts)
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
GBP_ACCESS_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Cloudflare (for deployment)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PAGES_PROJECT=
